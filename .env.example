# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=wins
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://wins:changeme@wins-db:5432/wins

# ─── Exchange APIs ───────────────────────────────────────────
# Which exchange to use for live orders: binance | coinbase
# Only matters when TRADE_MODE=live
EXCHANGE_BACKEND=binance

# Binance — Spot trading permission only. Enable IP allowlist on key.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Binance Testnet — get keys at https://testnet.binance.vision (sign in with GitHub)
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Coinbase Advanced Trade (stub — not yet implemented)
COINBASE_API_KEY=
COINBASE_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ─── Data Providers ──────────────────────────────────────────
COINGECKO_API_KEY=
LUNARCRUSH_API_KEY=
GLASSNODE_API_KEY=
GITHUB_TOKEN=
TWITTER_BEARER_TOKEN=

# ─── Alerts (Discord DM bot) ────────────────────────────────
# 1. discord.com/developers/applications → New App → Bot → Reset Token → copy
# 2. Invite bot to any server you're in:
#    https://discord.com/oauth2/authorize?client_id=YOUR_APP_CLIENT_ID&scope=bot&permissions=2048
# 3. Your user ID: Discord Settings → Advanced → Developer Mode
#    then right-click your name anywhere → Copy User ID
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# ─── Trade Mode ──────────────────────────────────────────────
# Options: paper | live
TRADE_MODE=paper

# ─── Brain Mode ──────────────────────────────────────────────
# USE_MOCK_BRAIN=true   → rule-based decisions, no Anthropic API calls
# USE_MOCK_BRAIN=false  → real Claude (requires ANTHROPIC_API_KEY)
USE_MOCK_BRAIN=true

# ─── System Config ───────────────────────────────────────────
DECISION_INTERVAL_MINUTES=15
LOG_LEVEL=INFO
